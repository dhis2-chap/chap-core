# Docker Compose overlay for optional services
# Copy this file to compose.override.yml to enable optional services.
# Docker Compose automatically merges compose.override.yml with compose.yml.
#
# Usage:
#   cp compose.override.yml.example compose.override.yml
#   docker compose up -d

services:
  # chtorch model (which uses chapkit)
  chtorch:
    image: ghcr.io/dhis2-chap/chtorch:chapkit2-8f17ee3
    ports:
      - "5001:8000"
    restart: unless-stopped

  # ewars plus
  # Built locally from external_models/ewars_plus_api_patch/ which overlays
  # the CLIM-617 get_preds bind_rows fix on top of maquins/ewars_plus_api:Upload.
  ewars_plus:
    build: ./external_models/ewars_plus_api_patch
    image: chap-core/ewars_plus_api:clim-617
    container_name: ewars_plus
    ports:
      - "3288:3288"
